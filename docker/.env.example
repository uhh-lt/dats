#################### INFO #####################
# This file allows us to override some of the #
# settings specified in production.yaml       #
#################### INFO #####################

### Docker settings
COMPOSE_PROJECT_NAME=demo
# Remove profiles to disable containers (from right to left)
# Dependencies are as follows:
# rq < backend < frontend
COMPOSE_PROFILES=rq,backend,frontend
# Docker tag to use for pulling the backend and rq container(s)
DATS_BACKEND_DOCKER_VERSION=1.9.3
# Docker tag to use for pulling the ray container
DATS_RAY_DOCKER_VERSION=1.9.3
# Docker tag to use for pulling the frontend
DATS_FRONTEND_DOCKER_VERSION=1.9.3
# Which user and group to use for running processes inside containers.
# Set this to the user and group you're using outside the containers to be able to read and write in folders mapped to volumes.
# use `id -u` and `id -g` to get your user and group id
DOCKER_UID=121
DOCKER_GID=126

### 3rd Party Tokens (used by DATS backend & vLLM)
HF_HUB_TOKEN=replace-me-with-your-own-token
# NUM DB CONNECTIONS
BACKEND_POSTGRES_POOL_SIZE=32
BACKEND_POSTGRES_MAX_OVERFLOW=16


### Backend & RQ settings
## VLLM connection
VLLM_LLM_HOST=vllm-llm
VLLM_LLM_PORT=8000
VLLM_LLM_MODEL=gemma-3-27b
VLLM_VLM_HOST=vllm-llm
VLLM_VLM_PORT=8000
VLLM_VLM_MODEL=gemma-3-27b
VLLM_EMB_HOST=vllm-emb
VLLM_EMB_PORT=8000
VLLM_EMB_MODEL=snowflake-arctic-embed-l-v2.0

## Ray connection
RAY_HOST=ray
RAY_PORT=8000

## Docling connection
DOCLING_HOST=docling
DOCLING_PORT=5001


### Redis settings
REDIS_PASSWORD=dats123


### Postgres settings
POSTGRES_DB=dats
POSTGRES_USER=datsuser
POSTGRES_PASSWORD=dats123
POSTGRES_DB=dats
POSTGRES_MAX_CONNECTIONS=200

### Redis settings
REDIS_PASSWORD=dats123

### RQ Worker settings
# LOG LEVEL ('critical', 'error', 'warning', 'info', 'debug', 'trace')
RQ_LOG_LEVEL=info
RQ_WORKERS_CPU=8
RQ_WORKERS_API=16
RQ_WORKERS_GPU=1
RQ_DEVICE_IDS=1

### RQ Dashboard settings
RQ_DASHBOARD_USERNAME=datsuser
RQ_DASHBOARD_PASSWORD=dats123
RQ_DASHBOARD_EXPOSED=13136

### DATS Backend API settings
# These are the critical settings!
# The backend can be fully customized using .env.backend
## Docker specific-settings:
API_WORKERS=10
API_EXPOSED=13120
## API:
# Use `python -c "import uuid; print(uuid.uuid4())"` to generate a UUID namespace for the backend
API_UUID_NAMESPACE=
## Auth:
# Use `pwgen` to generate a secret or use any long random string
AUTH_JWT_SECRET=
# Use `pwgen` to generate a secret or use any long random string
AUTH_SESSION_SECRET=
## Connections to external services:
# Ray
RAY_HOST=ray
RAY_PORT=8000
# VLLM
VLLM_LLM_HOST=vllm-llm
VLLM_LLM_PORT=8000
VLLM_VLM_HOST=vllm-llm
VLLM_VLM_PORT=8000
VLLM_EMB_HOST=vllm-emb
VLLM_EMB_PORT=8000
# Docling
DOCLING_HOST=docling
DOCLING_PORT=5001
# Glitchtip
BACKEND_GLITCHTIP_DSN=

### DATS Frontend settings
FRONTEND_EXPOSED=13100
FRONTEND_GLITCHTIP_DSN=

### Ray settings (compose.ray.yaml)
# LOG LEVEL ('critical', 'error', 'warning', 'info', 'debug', 'trace')
RAY_LOG_LEVEL=info
RAY_API_EXPOSED=13130
RAY_DASHBOARD_EXPOSED=13131
RAY_DEVICE_IDS=0
RAY_GLITCHTIP_DSN=


