#################### INFO ######################
# This file allows us to override all settings #
# specified in backend/configs/default.yaml    #
# Beware: settings in .env take precedence!    #
#################### INFO ######################

## API
API_MAX_UPLOAD_FILE_SIZE=209715200
API_PRODUCTION_MODE=1
API_IS_STABLE=True

## Auth
# OIDC
AUTH_OIDC_ENABLED=False
AUTH_OIDC_PROVIDER_NAME=Authentik
AUTH_OIDC_CLIENT_ID=put-client-id-here
AUTH_OIDC_CLIENT_SECRET=put-client-secret-here
AUTH_OIDC_SERVER_METADATA_URL=http://my-auth-server/application/o/dats/.well-known/openid-configuration

# Mail settings
MAIL_ENABLED=False
MAIL_FROM=dats@uni-hamburg.de
MAIL_USERNAME=USER
MAIL_PASSWORD=PASS
MAIL_SERVER=exchange.uni-hamburg.de
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
MAIL_USE_CREDENTIALS=True
MAIL_VALIDATE_CERTS=False

## Logging
# LOG LEVEL ('critical', 'error', 'warning', 'info', 'debug', 'trace')
LOG_LEVEL=info

## Users
SYSTEM_USER_PASSWORD=12SYSTEM34
DEMO_USER_PASSWORD=demo
ASSISTANT_USER_PASSWOD=12ASSISTANT34

## Postgres
POSTGRES_POOL_SIZE=32
POSTGRES_MAX_OVERFLOW=16

## Elasticsearch
ES_INDEX_PREFIX=dats

## VLLM
VLLM_LLM_MODEL=gemma-3-27b
VLLM_VLM_MODEL=gemma-3-27b
VLLM_EMB_MODEL=snowflake-arctic-embed-l-v2.0
