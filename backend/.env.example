#################### INFO ######################
# This file allows us to override all settings #
# specified in backend/configs/default.yaml    #
#################### INFO ######################

# API settings
API_PORT=13120
# Use `python -c "import uuid; print(uuid.uuid4())"` to generate a UUID namespace for the backend
API_UUID_NAMESPACE=
# Hugging Face settings for models
API_HF_HUB_TOKEN=replace-me-with-your-own-token

# AUTH settings
# Use `pwgen` to generate a secret or use any long random string
AUTH_JWT_SECRET=
# Use `pwgen` to generate a secret or use any long random string
AUTH_SESSION_SECRET=

# Connection configuration
# Tells the backend how to reach the various
# services it needs.
# Set _PORT values to their _EXPOSED counterparts
# if running outside a container,
# leave as-is otherwise.
CONTENT_SERVER_PORT=13121

RAY_HOST=localhost
RAY_PORT=13130

WEAVIATE_PORT=13132
WEAVIATE_GRPC_PORT=13134

POSTGRES_PORT=13122

REDIS_PORT=13124

ES_PORT=13125

VLLM_LLM_HOST=localhost
VLLM_LLM_PORT=13133
VLLM_LLM_MODEL=gemma-3-27b

VLLM_VLM_HOST=localhost
VLLM_VLM_PORT=13133
VLLM_VLM_MODEL=gemma-3-27b

VLLM_EMB_HOST=localhost
VLLM_EMB_PORT=13137
VLLM_EMB_MODEL=snowflake-arctic-embed-l-v2.0

DOCLING_HOST=localhost
DOCLING_PORT=13139

GLITCHTIP_DSN_BACKEND=
GLITCHTIP_DSN_FRONTEND=
