# URL for reaching the backend API.
# If the backend is running outside docker,
# use `API_PORT` from `backend/.env`.
# If running inside docker, use
# `API_EXPOSED` from `docker/.env`.
FRONTEND_API_URL=http://localhost:13120
# URL for reaching the content server.
# See `CONTENT_SERVER_EXPOSED` in `docker/.env`.
FRONTEND_CONTENT_URL=http://localhost:13121
# URL for reaching the glitchtip server.
# See `GLITCHTIP_EXPOSED` in `docker/.env`.
FRONTEND_GLITCHTIP_URL=http://localhost:13140
# Which port to listen on for the frontend
# development server.
FRONTEND_PORT=13100
